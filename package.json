{
  "name": "secureballot-server",
  "version": "0.1.0",
  "description": "SecureBallot backend: anonymous multi-tenant e-voting platform with Bull job queue",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "build": "bun build ./src/server.ts --target node --outdir ./dist --external '*'",
    "start": "bun dist/index.js",
    "worker": "bun run src/workers/emailWorker.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typeorm": "bun x ts-node --esm node_modules/typeorm/cli.js -d src/config/database.ts",
  "migration:run": "bun run typeorm migration:run",
 "migration:generate": "bun run src/scripts/generate-migration.ts",
  "migration:revert": "bun run typeorm migration:revert"
  },
  "dependencies": {
    "@vonage/messages": "^1.24.0",
    "@vonage/server-sdk": "^3.27.0",
    "bcrypt": "^5.1.1",
    "bull": "^4.11.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "redis": "^4.6.12",
    "resend": "^6.12.3",
    "secureballot-server": ".",
    "swagger": "^0.7.5",
    "typeorm": "^0.3.17",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/bun": "^1.3.14",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^6.4.14",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}